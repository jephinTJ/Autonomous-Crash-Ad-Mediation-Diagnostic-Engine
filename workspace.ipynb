      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "from tqdm.notebook import tqdm\n",
        "\n",
        "# 1. System Configuration\n",
        "n_requests = 1000000\n",
        "np.random.seed(42)\n",
        "\n",
        "# Device & Infrastructure Pools\n",
        "ram_tiers = [2048, 4096, 8192] # 2GB, 4GB, 8GB\n",
        "os_versions = ['Android 10', 'Android 11', 'Android 12', 'Android 13']\n",
        "ad_networks = ['AppLovin', 'IronSource', 'AdMob', 'UnityAds']\n",
        "sdk_versions = ['v3.8', 'v4.0', 'v4.1', 'v4.5']\n",
        "ad_types = ['Banner', 'Interstitial', 'Rewarded']\n",
        "\n",
        "data = []\n",
        "\n",
        "# 2. Generating the Infrastructure Logs\n",
        "for _ in tqdm(range(n_requests), desc=\"Generating Ad Mediation Logs\"):\n",
        "    ram = np.random.choice(ram_tiers, p=[0.3, 0.5, 0.2])\n",
        "    os_ver = np.random.choice(os_versions)\n",
        "    network = np.random.choice(ad_networks)\n",
        "    sdk = np.random.choice(sdk_versions)\n",
        "    ad_type = np.random.choice(ad_types, p=[0.5, 0.3, 0.2])\n",
        "\n",
        "    # Baseline health metrics\n",
        "    load_time_ms = int(np.random.normal(800, 200))\n",
        "    fill_rate = 1.0\n",
        "    crash_type = 'None'\n",
        "\n",
        "    # --- INJECTING TOXIC SYSTEM DISEASES ---\n",
        "\n",
        "    # Disease 1: The Memory Leak (UnityAds + Rewarded + 2GB RAM = OOM Crash)\n",
        "    if network == 'UnityAds' and ad_type == 'Rewarded' and ram == 2048:\n",
        "        if np.random.rand() > 0.2: # 80% chance to crash\n",
        "            crash_type = 'OOM_Exception'\n",
        "            load_time_ms = int(np.random.normal(4000, 500))\n",
        "            fill_rate = 0.0\n",
        "\n",
        "    # Disease 2: The Silent Fail (AppLovin SDK v4.1 = 0 Fill, No Crash)\n",
        "    elif network == 'AppLovin' and sdk == 'v4.1' and ad_type == 'Interstitial':\n",
        "        if np.random.rand() > 0.4: # 60% chance to silently fail\n",
        "            fill_rate = 0.0\n",
        "            load_time_ms = int(np.random.normal(300, 50)) # Fails fast\n",
        "\n",
        "    # Disease 3: The ANR Latency Spike (IronSource + Android 10 = Timeout)\n",
        "    elif network == 'IronSource' and os_ver == 'Android 10':\n",
        "        if np.random.rand() > 0.5:\n",
        "            crash_type = 'ANR_Timeout'\n",
        "            load_time_ms = int(np.random.normal(8000, 1000)) # Massive latency\n",
        "            fill_rate = 0.0\n",
        "\n",
        "    # Ensure no negative load times\n",
        "    load_time_ms = max(50, load_time_ms)\n",
        "\n",
        "    data.append([ram, os_ver, network, sdk, ad_type, load_time_ms, fill_rate, crash_type])\n",
        "\n",
        "df = pd.DataFrame(data, columns=['ram_mb', 'os_version', 'ad_network', 'sdk_version', 'ad_type', 'load_time_ms', 'fill_rate', 'crash_type'])\n",
        "\n",
        "# 3. Injecting Pipeline Chaos (Missing logs, null values)\n",
        "chaos_idx = df.sample(frac=0.03, random_state=42).index\n",
        "df.loc[chaos_idx, 'load_time_ms'] = np.nan # Corrupted latency tracking\n",
        "\n",
        "df.to_csv('ad_mediation_telemetry.csv', index=False)\n",
        "print(f\"\\nInfrastructure Telemetry Generated: {df.shape[0]} logs.\")\n",
        "print(df['crash_type'].value_counts())"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "### Phase 2: Unsupervised Anomaly Detection (Isolation Forest)\n",
        "Standard deterministic monitoring fails to capture 'Silent Fails'—instances where the ad mediation layer drops the fill rate to zero without throwing a fatal exception flag, resulting in invisible revenue bleed. To programmatically isolate these edge cases, I deployed an Isolation Forest (an unsupervised tree-based anomaly detection algorithm). By analyzing the multivariate geometry of `load_time_ms` and `fill_rate` across healthy logs, the model autonomously flags non-crashing requests that structurally deviate from baseline network health, enabling automated diagnostic alerting."
      ],
      "metadata": {
        "id": "z05Tphu0mZz-"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.ensemble import IsolationForest\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "print(\"Loading Infrastructure Logs & Cleaning Corrupted Latency...\")\n",
        "df = pd.read_csv('ad_mediation_telemetry.csv')\n",
        "df['crash_type'] = df['crash_type'].fillna('None') # Fix Pandas auto-converting the string 'None' to NaN\n",
        "\n",
        "# 1. Clean the chaos (Fill missing latencies with median to maintain mathematical integrity)\n",
        "median_latency = df['load_time_ms'].median()\n",
        "df['load_time_ms'] = df['load_time_ms'].fillna(median_latency)\n",
        "\n",
        "# 2. Isolate the \"Healthy\" looking logs (No hard crashes)\n",
        "# We want the AI to find the invisible bugs hiding in the normal traffic\n",
        "df_silent = df[df['crash_type'] == 'None'].copy()\n",
        "\n",
        "print(f\"Analyzing {df_silent.shape[0]} 'crash-free' logs for invisible anomalies...\")\n",
        "\n",
        "# 3. Prepare features for the Isolation Forest\n",
        "# We scale the features so latency (ms) and fill_rate (0-1) are mathematically comparable\n",
        "X = df_silent[['load_time_ms', 'fill_rate']]\n",
        "\n",
        "# 4. Deploy Isolation Forest\n",
        "print(\"Deploying Unsupervised Isolation Forest...\")\n",
        "iso_forest = IsolationForest(n_estimators=100, contamination=0.05, random_state=42)\n",
        "df_silent['anomaly_score'] = iso_forest.fit_predict(X)\n",
        "\n",
        "# 5. Extract the anomalies (-1 means Anomaly, 1 means Normal)\n",
        "anomalies = df_silent[df_silent['anomaly_score'] == -1]\n",
        "\n",
        "print(f\"\\nIsolation Forest successfully flagged {anomalies.shape[0]} silent anomalies.\")\n",
        "\n",
        "# Let's prove the AI found our injected AppLovin v4.1 disease\n",
        "print(\"\\n--- Top SDKs involved in Invisible Anomalies ---\")\n",
        "print(anomalies.groupby(['ad_network', 'sdk_version']).size().sort_values(ascending=False).head(3))"
      ],
